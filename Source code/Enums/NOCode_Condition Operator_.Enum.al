enum 80213 "Condition Operator"
{
    Extensible = true;

    value(0; "=")
    {
        Caption = '=';
    }
    value(1; ">")
    {
        Caption = '>';
    }
    value(2; "<")
    {
        Caption = '<';
    }
    value(3; ">=")
    {
        Caption = '>=';
    }
    value(4; "<=")
    {
        Caption = '<=';
    }
    value(5; "<>")
    {
        Caption = '<>';
    }
}